# =============================================================================
# Smart Training — PRODUÇÃO (template — pode commitar)
# =============================================================================
# NÃO coloque senhas reais aqui. Copie para o servidor com outro nome:
#
#   Opção A (Dokploy UI): cole cada variável na aba Environment do app
#   Opção B (arquivo no VPS): cp .env.production.example .env.production
#                           nano .env.production   # preencha os valores
#
# O arquivo real (.env.production ou .env) fica SÓ no servidor, nunca no git.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Smart Training
APP_ENV=production
APP_DEBUG=false

# ── Banco (MySQL) ────────────────────────────────────────────────────────────
# Dokploy com compose (serviço "db" na mesma rede):
#   DATABASE_URL=mysql+pymysql://smart_user:SENHA_FORTE@db:3306/smart_training
#
# MySQL separado no Dokploy (use o hostname interno que o painel mostra):
#   DATABASE_URL=mysql+pymysql://user:senha@smart-training-db:3306/smart_training
#
DATABASE_URL=mysql+pymysql://smart_user:ALTERAR_SENHA@db:3306/smart_training

MYSQL_ROOT_PASSWORD=ALTERAR_ROOT
MYSQL_DATABASE=smart_training
MYSQL_USER=smart_user
MYSQL_PASSWORD=ALTERAR_SENHA

# ── JWT (obrigatório trocar) ─────────────────────────────────────────────────
# Gere: openssl rand -hex 32
JWT_SECRET_KEY=ALTERAR_COM_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin inicial (seed na 1ª execução) ──────────────────────────────────────
ADMIN_EMAIL=admin@smarttraining.com
ADMIN_PASSWORD=ALTERAR_SENHA_FORTE

# ── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=uploads

# ── CORS (domínio real do frontend) ─────────────────────────────────────────
CORS_ORIGINS=https://app.seudominio.com,https://www.seudominio.com

# ── Docker Compose (porta publicada no host, se usar) ───────────────────────
API_PORT=9030
